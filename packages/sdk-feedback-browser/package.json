{
  "name": "tracebility-feedback-browser",
  "version": "0.0.1",
  "description": "Browser-side SDK for posting end-user feedback (thumbs / scores / comments) to a tracebility ingest host using a public tbf_pub_* key. Zero deps, ~2KB minified.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "llm",
    "observability",
    "feedback",
    "tracing",
    "tracebility"
  ],
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
