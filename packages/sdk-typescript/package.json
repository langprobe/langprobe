{
  "name": "tracebility-langsmith-shim",
  "version": "0.0.1",
  "description": "Drop-in compat shim that lets LangSmith-style JS/TS code (Client + traceable + wrapOpenAI/wrapAnthropic) post to a tracebility ingest host. Nominative fair use only; not affiliated with LangChain Inc.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --import tsx test/*.test.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "llm",
    "observability",
    "tracing",
    "langsmith",
    "compat"
  ],
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  }
}
